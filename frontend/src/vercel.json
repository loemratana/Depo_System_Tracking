{
    "version": 2,
    "buildCommand": "npm run build",
    "framework": "vite",
    "functions": {
        "dist/server/server.js": {
            "runtime": "nodejs22.x"
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/dist/server/server.js"
        }
    ]
}