# ──────────────────────────────────────────────
# Frontend environment (example)
# Copy to `.env` and adjust if needed:
#   cp .env.example .env
# Never commit your real `.env` file.
#
# Vite only exposes variables prefixed with VITE_
# ──────────────────────────────────────────────

# Backend API origin used by the Vite dev proxy (/api, /uploads)
VITE_API_PROXY_TARGET=http://localhost:5000

# Public API / asset base (used for image URLs when not going through the proxy)
VITE_API_BASE_URL=http://localhost:5000

# App display name (optional)
VITE_APP_NAME=Brand Depot Tracking
