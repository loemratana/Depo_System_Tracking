<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Depot Report</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Arial', sans-serif;
            padding: 20px;
            color: #2c3e50;
            line-height: 1.6;
        }
        .header {
            text-align: center;
            border-bottom: 3px solid #2c3e50;
            padding-bottom: 12px;
            margin-bottom: 20px;
        }
        .logo {
            max-height: 60px;
            margin-bottom: 8px;
        }
        .title {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: 1px;
            color: #1a1a2e;
        }
        .subtitle {
            font-size: 14px;
            color: #7f8c8d;
            margin-top: 4px;
        }
        .summary {
            background: #f8f9fa;
            padding: 16px 20px;
            border-radius: 8px;
            margin: 20px 0;
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            border-left: 4px solid #3498db;
        }
        .summary-item {
            text-align: center;
            padding: 4px 16px;
        }
        .summary-item .label {
            font-size: 12px;
            color: #7f8c8d;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .summary-item .value {
            font-size: 22px;
            font-weight: 700;
            color: #2c3e50;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 16px;
            font-size: 12px;
        }
        th {
            background: #2c3e50;
            color: white;
            padding: 10px 8px;
            text-align: left;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 0.5px;
        }
        td {
            padding: 8px;
            border-bottom: 1px solid #e0e0e0;
        }
        tr:hover {
            background: #f1f5f9;
        }
        .footer {
            text-align: center;
            font-size: 11px;
            color: #95a5a6;
            margin-top: 30px;
            border-top: 1px solid #e0e0e0;
            padding-top: 16px;
        }
        .page-number {
            font-weight: 700;
        }
    </style>
</head>
<body>
<div class="header">
    {{#if companyLogo}}
        <img src="{{companyLogo}}" class="logo" alt="Company Logo" />
    {{/if}}
    <div class="title">Depot Report</div>
    <div class="subtitle">Generated on {{generatedAt}}</div>
</div>

<div class="summary">
    <div class="summary-item">
        <div class="label">Total Depots</div>
        <div class="value">{{totalDepots}}</div>
    </div>
    <div class="summary-item">
        <div class="label">Active</div>
        <div class="value">{{activeDepots}}</div>
    </div>
    <div class="summary-item">
        <div class="label">Expiring Soon (&lt;30d)</div>
        <div class="value">{{expiringSoon}}</div>
    </div>
</div>

<table>
    <thead>
    <tr>
        <th>Code</th>
        <th>Name</th>
        <th>Province</th>
        <th>District</th>
        <th>Status</th>
        <th>Expiry Date</th>
    </tr>
    </thead>
    <tbody>
    {{#each depots}}
        <tr>
            <td>{{code}}</td>
            <td>{{name}}</td>
            <td>{{provinceName}}</td>
            <td>{{districtName}}</td>
            <td>{{status}}</td>
            <td>{{expiryDate}}</td>
        </tr>
    {{/each}}
    </tbody>
</table>

<div class="footer">
    Confidential – Generated by Depot System
</div>
</body>
</html>