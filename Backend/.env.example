# ──────────────────────────────────────────────
# Backend environment (example)
# Copy to `.env` and fill in real values:
#   cp .env.example .env
# Never commit your real `.env` file.
# ──────────────────────────────────────────────

NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database (Supabase / PostgreSQL)
# Use URL-encoded password if it contains special characters (@ → %40)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d
JWT_RESET_EXPIRY=1h
JWT_VERIFY_EXPIRY=24h
JWT_ISSUER=depot-management-api
JWT_AUDIENCE=depot-management-client

# Session (required if using Redis session store)
SESSION_SECRET=change-me-session-secret

# Security / rate limiting
ARCJET_ENV=development
ARCJET_KEY=
ENABLE_ARCJET=false
ENABLE_RATE_LIMIT=false

# Upstash Redis (sessions / cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: public base URL of this API (for links / logos)
TARGET_API=http://localhost:5000
COMPANY_LOGO_URL=

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=
