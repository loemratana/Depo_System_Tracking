generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Province {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(100)
  code      String?    @unique @db.VarChar(20)
  createdAt DateTime   @default(now()) @map("created_at")
  depots    Depot[]
  districts District[]

  @@map("provinces")
}

model District {
  id         Int      @id @default(autoincrement())
  provinceId Int      @map("province_id")
  name       String   @db.VarChar(100)
  code       String?  @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")
  depots     Depot[]
  province   Province @relation(fields: [provinceId], references: [id])

  @@map("districts")
}

model Employee {
  id                  Int                  @id @default(autoincrement())
  employeeCode        String?              @unique @map("employee_code") @db.VarChar(50)
  position            String?              @db.VarChar(100)
  phone               String?              @db.VarChar(20)
  email               String?              @db.VarChar(100)
  hireDate            DateTime?            @map("hire_date") @db.Date
  status              EmployeeStatus       @default(active)
  createdAt           DateTime             @default(now()) @map("created_at")
  address             String?
  dateOfBirth         DateTime?            @map("date_of_birth") @db.Date
  department          String?              @db.VarChar(100)
  englishName         String?              @map("english_name") @db.VarChar(100)
  gender              String?
  images              String?
  khmerName           String?              @map("khmer_name") @db.VarChar(100)
  salary              Float?               @db.Real
  updatedAt           DateTime?            @updatedAt @map("updated_at")
  remarks             String?              @db.Text
  depots              Depot[]
  user                User?
  kpis                EmployeeKPI[]
  productPerformances ProductPerformance[]
  documents           EmployeeDocument[]

  @@map("employees")
}

model Depot {
  id          Int           @id @default(autoincrement())
  districtId  Int           @map("district_id")
  name        String        @db.VarChar(100)
  khmerName   String?       @map("khmer_name") @db.VarChar(100)
  code        String?       @unique @db.VarChar(50)
  address     String?
  phone       String?       @db.VarChar(20)
  status      DepotStatus   @default(active)
  createdAt   DateTime      @default(now()) @map("created_at")
  commune     String?       @db.VarChar(100)
  employeeId  Int?          @map("employee_id")
  expiryDate  DateTime?     @map("expiry_date") @db.Timestamptz(6)
  houseNumber String?       @map("house_number") @db.VarChar(50)
  provinceId  Int?          @map("province_id")
  street      String?       @db.VarChar(100)
  village     String?       @db.VarChar(100)
  brandId     Int?          @map("brand_id")
  assignedAt  DateTime?     @map("assigned_at")
  district    District      @relation(fields: [districtId], references: [id])
  employee    Employee?     @relation(fields: [employeeId], references: [id])
  brand       Brand?        @relation(fields: [brandId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_brand")
  province    Province?     @relation(fields: [provinceId], references: [id], map: "fk_depot_province")
  products    Product[]
  kpis        EmployeeKPI[]

  @@index([createdAt], map: "idx_depots_created_at")
  @@index([districtId], map: "idx_depots_district_id")
  @@index([name], map: "idx_name_depot")
  @@map("depots")
}

model Brand {
  id          Int         @id @default(autoincrement())
  name        String      @db.VarChar(100)
  code        String?     @unique @db.VarChar(50)
  description String?
  status      BrandStatus @default(active)
  createdAt   DateTime    @default(now()) @map("created_at")
  depots      Depot[]
  products    Product[]

  @@map("brands")
}

model Product {
  id           Int                  @id @default(autoincrement())
  brandId      Int                  @map("brand_id")
  depotId      Int                  @map("depot_id")
  name         String               @db.VarChar(200)
  sku          String?              @unique @db.VarChar(100)
  price        Decimal?             @db.Decimal(10, 2)
  quantity     Int                  @default(0)
  minStock     Int                  @default(0) @map("min_stock")
  status       ProductStatus        @default(OK)
  createdAt    DateTime             @default(now()) @map("created_at")
  brand        Brand                @relation(fields: [brandId], references: [id])
  depot        Depot                @relation(fields: [depotId], references: [id])
  performances ProductPerformance[]

  @@map("products")
}

model User {
  id           Int            @id @default(autoincrement())
  employeeId   Int?           @unique @map("employee_id")
  username     String         @unique @db.VarChar(50)
  passwordHash String         @map("password_hash") @db.VarChar(255)
  role         UserRole       @default(staff)
  lastLogin    DateTime?      @map("last_login")
  status       UserStatus     @default(active)
  createdAt    DateTime       @default(now()) @map("created_at")
  refreshToken RefreshToken[]
  reports      Report[]
  employee     Employee?      @relation(fields: [employeeId], references: [id])

  @@map("users")
}

model Report {
  id          Int        @id @default(autoincrement())
  generatedBy Int        @map("generated_by")
  reportType  ReportType @map("report_type")
  title       String     @db.VarChar(200)
  parameters  Json?
  filePath    String?    @map("file_path") @db.VarChar(500)
  generatedAt DateTime   @default(now()) @map("generated_at")
  user        User       @relation(fields: [generatedBy], references: [id])

  @@map("reports")
}

model RefreshToken {
  id        String   @id @map("refresh_tokens_pkey")
  token     String   @unique @map("refresh_tokens_token_key")
  userId    Int      @map("user_id")
  isRevoked Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum DepotStatus {
  active
  inactive
}

enum BrandStatus {
  active
  inactive
}

enum ProductStatus {
  OK
  LOW
  OUT_OF_STOCK
}

enum EmployeeStatus {
  active
  inactive
}

enum UserRole {
  admin
  manager
  staff
  viewer
}

enum UserStatus {
  active
  locked
}

enum ReportType {
  inventory
  sales
  employee
  depot
}

enum DepotBrandStatus {
  active
  inactive
}

model EmployeeKPI {
  id          Int      @id @default(autoincrement())
  employeeId  Int      @map("employee_id")
  depotId     Int      @map("depot_id")
  month       DateTime @db.Date
  targetValue Float    @map("target_value")
  actualValue Float    @default(0) @map("actual_value")
  performance Float?
  remarks     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])
  depot    Depot    @relation(fields: [depotId], references: [id])

  @@unique([employeeId, depotId, month])
  @@map("employee_kpis")
}

model ProductPerformance {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  employeeId   Int      @map("employee_id")
  month        DateTime @db.Date
  quantitySold Int      @default(0) @map("quantity_sold")
  revenue      Decimal  @default(0) @db.Decimal(10, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  product  Product  @relation(fields: [productId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("product_performances")
}

model EmployeeDocument {
  id         Int      @id @default(autoincrement())
  employeeId Int      @map("employee_id")
  fileName   String   @map("file_name") @db.VarChar(200)
  fileUrl    String   @map("file_url")
  fileType   String?  @map("file_type")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_documents")
}
